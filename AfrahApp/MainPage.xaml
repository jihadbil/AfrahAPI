<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:AfrahApp.ViewModels"
             xmlns:models="clr-namespace:AfrahApp.Models.Home"
             xmlns:bookingModels="clr-namespace:AfrahApp.Models.Booking"
             x:Class="AfrahApp.MainPage"
             x:DataType="viewModels:MainViewModel"
             FlowDirection="RightToLeft"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F6F6"
             Title="الرئيسية">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="#FFFFFF"
                Padding="16,14">
            <Border.Shadow>
                <Shadow Brush="#12000000" Offset="0,2" Radius="8" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto" FlowDirection="LeftToRight" VerticalOptions="Center">
                <Grid HeightRequest="42" WidthRequest="42" IsVisible="{Binding IsHeaderBellVisible}">
                    <Button Text="🔔"
                            FontSize="22"
                            BackgroundColor="#F8F6F6"
                            CornerRadius="21"
                            Padding="0"
                            BorderWidth="0"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />

                    <Border HeightRequest="10"
                            WidthRequest="10"
                            BackgroundColor="#E6195D"
                            Stroke="White"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 5"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,4,4,0" />
                </Grid>

                <Button IsVisible="{Binding IsHeaderFilterVisible}"
                        Text="☷"
                        FontSize="24"
                        BackgroundColor="#F8F6F6"
                        CornerRadius="21"
                        Padding="0"
                        BorderWidth="0"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        HeightRequest="42"
                        WidthRequest="42" />

                <Button IsVisible="{Binding IsHeaderSaveVisible}"
                        Text="حفظ"
                        TextColor="#E6195D"
                        FontSize="18"
                        FontAttributes="Bold"
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        Padding="0,0,8,0"
                        HorizontalOptions="Start"
                        VerticalOptions="Center" />

                <Label Grid.Column="1"
                       Text="{Binding ActiveSectionTitle}"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="#181113" />

                <Button Grid.Column="2"
                        Text="{Binding HeaderActionIcon}"
                        Command="{Binding HeaderActionCommand}"
                        FontSize="24"
                        BackgroundColor="#F8F6F6"
                        CornerRadius="21"
                        HeightRequest="42"
                        WidthRequest="42"
                        Padding="0"
                        BorderWidth="0" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="18">
                <VerticalStackLayout IsVisible="{Binding IsHomeSectionVisible}" Spacing="18">
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            Padding="16">
                        <Border.Shadow>
                            <Shadow Brush="#26000000" Offset="0,4" Radius="16" />
                        </Border.Shadow>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E6195D" Offset="0" />
                                <GradientStop Color="#B00C42" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid ColumnDefinitions="*,Auto" FlowDirection="RightToLeft">
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding WelcomeBackText}"
                                       TextColor="#FFFFFF"
                                       Opacity="0.85"
                                       FontSize="20" />
                                <Label Text="{Binding UserName}"
                                       TextColor="#FFFFFF"
                                       FontSize="42"
                                       FontAttributes="Bold" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="⭐" FontSize="18" />
                                    <Label Text="{Binding MembershipText}"
                                           TextColor="#FFFFFF"
                                           FontSize="20"
                                           Opacity="0.92" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    HeightRequest="92"
                                    WidthRequest="92"
                                    Stroke="#66FFFFFF"
                                    StrokeThickness="2"
                                    StrokeShape="RoundRectangle 46"
                                    Padding="2"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center">
                                <Image Source="{Binding ProfileAvatarUrl}"
                                       Aspect="AspectFill"
                                       HeightRequest="88"
                                       WidthRequest="88" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="عرض الكل"
                               FontSize="18"
                               TextColor="#E6195D"
                               VerticalTextAlignment="Center" />
                        <Label Grid.Column="1"
                               Text="ملخص الحجوزات"
                               FontSize="44"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="End"
                               TextColor="#181113" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Border Grid.Column="0"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="#FFFFFF"
                                Padding="10,14">
                            <Border.Shadow>
                                <Shadow Brush="#13000000" Offset="0,2" Radius="10" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border HeightRequest="58"
                                        WidthRequest="58"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 29"
                                        BackgroundColor="#EEF4FF"
                                        HorizontalOptions="Center">
                                    <Label Text="📅"
                                           FontSize="26"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                                <Label Text="{Binding ActiveBookingsCount}" FontSize="44" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                <Label Text="نشطة" FontSize="18" TextColor="#88636F" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="#FFFFFF"
                                Padding="10,14">
                            <Border.Shadow>
                                <Shadow Brush="#13000000" Offset="0,2" Radius="10" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border HeightRequest="58"
                                        WidthRequest="58"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 29"
                                        BackgroundColor="#FFF4E8"
                                        HorizontalOptions="Center">
                                    <Label Text="⌛"
                                           FontSize="26"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                                <Label Text="{Binding PendingBookingsCount}" FontSize="44" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                <Label Text="في الانتظار" FontSize="18" TextColor="#88636F" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="#FFFFFF"
                                Padding="10,14">
                            <Border.Shadow>
                                <Shadow Brush="#13000000" Offset="0,2" Radius="10" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border HeightRequest="58"
                                        WidthRequest="58"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 29"
                                        BackgroundColor="#EAF8EF"
                                        HorizontalOptions="Center">
                                    <Label Text="✅"
                                           FontSize="26"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                                <Label Text="{Binding CompletedBookingsCount}" FontSize="44" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                <Label Text="مكتملة" FontSize="18" TextColor="#88636F" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                        <Label Text="استكشف"
                               FontSize="18"
                               TextColor="#E6195D"
                               VerticalTextAlignment="Center" />
                        <Label Grid.Column="1"
                               Text="قاعات مقترحة لك"
                               FontSize="44"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="End"
                               TextColor="#181113" />
                    </Grid>

                    <ScrollView Orientation="Horizontal">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding RecommendedHalls}" Spacing="12">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:HomeHallCard">
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18"
                                            BackgroundColor="#FFFFFF"
                                            WidthRequest="280">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenHallDetailsCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Shadow>
                                            <Shadow Brush="#13000000" Offset="0,2" Radius="10" />
                                        </Border.Shadow>
                                        <Grid RowDefinitions="160,Auto">
                                            <Grid HeightRequest="160">
                                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />

                                                <Border HeightRequest="40"
                                                        WidthRequest="40"
                                                        BackgroundColor="#F8F6F6"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 20"
                                                        HorizontalOptions="End"
                                                        VerticalOptions="Start"
                                                        Margin="10">
                                                    <Label Text="❤"
                                                           TextColor="#E6195D"
                                                           FontSize="22"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center" />
                                                </Border>

                                                <Border StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 10"
                                                        BackgroundColor="#78000000"
                                                        HorizontalOptions="Start"
                                                        VerticalOptions="End"
                                                        Margin="10"
                                                        Padding="8,4">
                                                    <HorizontalStackLayout Spacing="3">
                                                        <Label Text="⭐" FontSize="14" />
                                                        <Label Text="{Binding RatingText}" TextColor="White" FontSize="16" FontAttributes="Bold" />
                                                    </HorizontalStackLayout>
                                                </Border>
                                            </Grid>

                                            <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="6">
                                                <Label Text="{Binding Name}" FontSize="28" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                                <HorizontalStackLayout Spacing="4">
                                                    <Label Text="📍" FontSize="16" />
                                                    <Label Text="{Binding Location}" FontSize="16" TextColor="#88636F" LineBreakMode="TailTruncation" />
                                                </HorizontalStackLayout>

                                                <Grid ColumnDefinitions="Auto,*" Margin="0,4,0,0">
                                                    <Button Text="حجز الآن"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenHallDetailsCommand}"
                                                            CommandParameter="{Binding .}"
                                                            FontSize="18"
                                                            BackgroundColor="#FCE7EF"
                                                            TextColor="#E6195D"
                                                            BorderWidth="0"
                                                            CornerRadius="14"
                                                            Padding="16,8"
                                                            HorizontalOptions="Start" />

                                                    <Label Grid.Column="1"
                                                           Text="{Binding PriceText}"
                                                           FontSize="30"
                                                           TextColor="#E6195D"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="End"
                                                           VerticalTextAlignment="Center" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <Label Text="تحديثات حديثة"
                           FontSize="44"
                           FontAttributes="Bold"
                           TextColor="#181113"
                           HorizontalTextAlignment="End"
                           Margin="0,4,0,0" />

                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="#FFFFFF"
                            Padding="14">
                        <Border.Shadow>
                            <Shadow Brush="#13000000" Offset="0,2" Radius="10" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto,*" FlowDirection="LeftToRight">
                            <Border HeightRequest="52"
                                    WidthRequest="52"
                                    StrokeThickness="0"
                                    BackgroundColor="#FCE7EF"
                                    StrokeShape="RoundRectangle 26"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Center">
                                <Label Text="🎟"
                                       FontSize="24"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Text="منذ 2 ساعة" FontSize="14" TextColor="#B0939E" />
                                    <Label Grid.Column="1"
                                           Text="خصم خاص 20%"
                                           FontSize="36"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="End" />
                                </Grid>

                                <Label Text="احصل على خصم خاص عند حجز قاعة المرجان خلال هذا الأسبوع."
                                       FontSize="20"
                                       TextColor="#88636F"
                                       HorizontalTextAlignment="End"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsHallsSectionVisible}" Spacing="12">
                    <Border Stroke="#DFD9DB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="#FFFFFF"
                            Padding="10,6">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <Label Text="⌕"
                                   FontSize="24"
                                   TextColor="#8A6E77"
                                   VerticalTextAlignment="Center" />

                            <Entry Grid.Column="1"
                                   Text="{Binding HallSearchQuery}"
                                   Placeholder="ابحث عن الصالات بالاسم أو الموقع..."
                                   FontSize="17"
                                   BackgroundColor="Transparent"
                                   TextColor="#181113"
                                   PlaceholderColor="#8A6E77"
                                   HorizontalTextAlignment="End" />

                            <Border Grid.Column="2"
                                    HeightRequest="34"
                                    WidthRequest="34"
                                    StrokeThickness="0"
                                    BackgroundColor="#FCE7EF"
                                    StrokeShape="RoundRectangle 17">
                                <Label Text="☷"
                                       FontSize="16"
                                       TextColor="#E6195D"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="8" FlowDirection="RightToLeft">
                            <Border BackgroundColor="#E6195D"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="14,8">
                                <HorizontalStackLayout Spacing="4" FlowDirection="LeftToRight">
                                    <Label Text="☷" FontSize="14" TextColor="White" />
                                    <Label Text="الكل"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </HorizontalStackLayout>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#E9E3E5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="16,8">
                                <HorizontalStackLayout Spacing="4" FlowDirection="LeftToRight">
                                    <Label Text="⌄" FontSize="13" TextColor="#181113" />
                                    <Label Text="السعر" FontSize="15" TextColor="#181113" />
                                </HorizontalStackLayout>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#E9E3E5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="16,8">
                                <HorizontalStackLayout Spacing="4" FlowDirection="LeftToRight">
                                    <Label Text="⌄" FontSize="13" TextColor="#181113" />
                                    <Label Text="الموقع" FontSize="15" TextColor="#181113" />
                                </HorizontalStackLayout>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#E9E3E5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="16,8">
                                <HorizontalStackLayout Spacing="4" FlowDirection="LeftToRight">
                                    <Label Text="⌄" FontSize="13" TextColor="#181113" />
                                    <Label Text="التقييم" FontSize="15" TextColor="#181113" />
                                </HorizontalStackLayout>
                            </Border>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <VerticalStackLayout IsVisible="{Binding HasFeaturedHall}">
                        <Border BindingContext="{Binding FeaturedHall}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="#FFFFFF">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenHallDetailsCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Border.Shadow>
                                <Shadow Brush="#13000000" Offset="0,2" Radius="10" />
                            </Border.Shadow>
                            <Grid RowDefinitions="220,Auto">
                                <Grid HeightRequest="220">
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />

                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="#F8F6F6"
                                            HorizontalOptions="Start"
                                            VerticalOptions="Start"
                                            Margin="12"
                                            Padding="10,4">
                                        <HorizontalStackLayout Spacing="2" FlowDirection="LeftToRight">
                                            <Label Text="{Binding RatingText}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="#181113" />
                                            <Label Text="⭐" FontSize="16" />
                                        </HorizontalStackLayout>
                                    </Border>

                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 20"
                                            BackgroundColor="{Binding AvailabilityBadgeBackgroundColor}"
                                            HeightRequest="40"
                                            WidthRequest="40"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start"
                                            Margin="12">
                                        <Label Text="{Binding AvailabilityBadgeText}"
                                               TextColor="White"
                                               FontSize="18"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>
                                </Grid>

                                <VerticalStackLayout Grid.Row="1" Padding="14,12" Spacing="8">
                                    <Label Text="{Binding Name}"
                                           FontSize="38"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />

                                    <HorizontalStackLayout Spacing="4" HorizontalOptions="End">
                                        <Label Text="📍" FontSize="16" />
                                        <Label Text="{Binding Location}"
                                               FontSize="16"
                                               TextColor="#88636F"
                                               LineBreakMode="TailTruncation" />
                                    </HorizontalStackLayout>

                                    <BoxView HeightRequest="1" Color="#F1ECEE" Margin="0,4,0,0" />

                                    <Grid ColumnDefinitions="Auto,*" Margin="0,6,0,0">
                                        <Button Text="احجز الآن"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenHallDetailsCommand}"
                                                CommandParameter="{Binding .}"
                                                FontSize="18"
                                                BackgroundColor="#E6195D"
                                                TextColor="White"
                                                BorderWidth="0"
                                                CornerRadius="14"
                                                Padding="20,8"
                                                HorizontalOptions="Start" />

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="0"
                                                             HorizontalOptions="End">
                                            <Label Text="{Binding PriceHintText}"
                                                   FontSize="14"
                                                   TextColor="#88636F"
                                                   HorizontalTextAlignment="End" />
                                            <HorizontalStackLayout Spacing="3"
                                                                   HorizontalOptions="End"
                                                                   FlowDirection="LeftToRight">
                                                <Label Text="{Binding PriceValueText}"
                                                       FontSize="42"
                                                       FontAttributes="Bold"
                                                       TextColor="#E6195D" />
                                                <Label Text="/ الليلة"
                                                       FontSize="14"
                                                       TextColor="#88636F"
                                                       VerticalTextAlignment="End" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding HighlightedHalls}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:HomeHallCard">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 18"
                                        BackgroundColor="#FFFFFF">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenHallDetailsCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Border.Shadow>
                                        <Shadow Brush="#13000000" Offset="0,2" Radius="10" />
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="*,150" ColumnSpacing="10" HeightRequest="152">
                                        <VerticalStackLayout Grid.Column="0" Padding="10,8" Spacing="3">
                                            <Grid ColumnDefinitions="Auto,*" FlowDirection="LeftToRight">
                                                <Border BackgroundColor="#F8F6F6"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 8"
                                                        Padding="6,2"
                                                        HorizontalOptions="Start">
                                                    <HorizontalStackLayout Spacing="1" FlowDirection="LeftToRight">
                                                        <Label Text="{Binding RatingText}" FontSize="16" FontAttributes="Bold" />
                                                        <Label Text="⭐" FontSize="12" />
                                                    </HorizontalStackLayout>
                                                </Border>

                                                <Label Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontSize="20"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="End"
                                                       LineBreakMode="TailTruncation" />
                                            </Grid>

                                            <HorizontalStackLayout Spacing="2" HorizontalOptions="End">
                                                <Label Text="📍" FontSize="14" />
                                                <Label Text="{Binding Location}"
                                                       FontSize="14"
                                                       TextColor="#88636F"
                                                       LineBreakMode="TailTruncation" />
                                            </HorizontalStackLayout>

                                            <Label Text="{Binding CapacityText}"
                                                   FontSize="14"
                                                   TextColor="#88636F"
                                                   HorizontalTextAlignment="End" />

                                            <Grid ColumnDefinitions="Auto,*" VerticalOptions="EndAndExpand">
                                                <Label Text="التفاصيل"
                                                       FontSize="18"
                                                       TextColor="#E6195D"
                                                       FontAttributes="Bold"
                                                       VerticalTextAlignment="End" />

                                                <Label Grid.Column="1"
                                                       Text="{Binding PriceValueText}"
                                                       FontSize="34"
                                                       FontAttributes="Bold"
                                                       TextColor="#E6195D"
                                                       HorizontalTextAlignment="End"
                                                       VerticalTextAlignment="End" />
                                            </Grid>
                                        </VerticalStackLayout>

                                        <Grid Grid.Column="1" HeightRequest="152">
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />

                                            <Border StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 18"
                                                    BackgroundColor="{Binding AvailabilityBadgeBackgroundColor}"
                                                    HeightRequest="34"
                                                    WidthRequest="34"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Start"
                                                    Margin="8">
                                                <Label Text="{Binding AvailabilityBadgeText}"
                                                       TextColor="White"
                                                       FontSize="16"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>

                                            <Border IsVisible="{Binding HasTag}"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 10"
                                                    BackgroundColor="#78000000"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="End"
                                                    Margin="8"
                                                    Padding="8,3">
                                                <Label Text="{Binding TagText}"
                                                       FontSize="12"
                                                       TextColor="White" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" BindableLayout.ItemsSource="{Binding HallsGridLeft}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:HomeHallCard">
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18"
                                            BackgroundColor="#FFFFFF">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenHallDetailsCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Shadow>
                                            <Shadow Brush="#13000000" Offset="0,2" Radius="10" />
                                        </Border.Shadow>
                                        <Grid RowDefinitions="130,Auto">
                                            <Grid HeightRequest="130">
                                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                                <Border StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 16"
                                                        BackgroundColor="{Binding AvailabilityBadgeBackgroundColor}"
                                                        HeightRequest="30"
                                                        WidthRequest="30"
                                                        HorizontalOptions="End"
                                                        VerticalOptions="Start"
                                                        Margin="8">
                                                    <Label Text="{Binding AvailabilityBadgeText}"
                                                           TextColor="White"
                                                           FontSize="14"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center" />
                                                </Border>
                                            </Grid>

                                            <VerticalStackLayout Grid.Row="1" Padding="10,8" Spacing="3">
                                                <Label Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="End"
                                                       LineBreakMode="TailTruncation" />
                                                <HorizontalStackLayout Spacing="2" HorizontalOptions="End">
                                                    <Label Text="📍" FontSize="12" />
                                                    <Label Text="{Binding Location}"
                                                           FontSize="12"
                                                           TextColor="#88636F"
                                                           LineBreakMode="TailTruncation" />
                                                </HorizontalStackLayout>
                                                <Grid ColumnDefinitions="Auto,*" FlowDirection="LeftToRight">
                                                    <HorizontalStackLayout Spacing="1">
                                                        <Label Text="{Binding RatingText}" FontSize="12" TextColor="#88636F" />
                                                        <Label Text="⭐" FontSize="10" />
                                                    </HorizontalStackLayout>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding PriceValueText}"
                                                           FontSize="16"
                                                           FontAttributes="Bold"
                                                           TextColor="#E6195D"
                                                           HorizontalTextAlignment="End" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" BindableLayout.ItemsSource="{Binding HallsGridRight}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:HomeHallCard">
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18"
                                            BackgroundColor="#FFFFFF">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenHallDetailsCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Shadow>
                                            <Shadow Brush="#13000000" Offset="0,2" Radius="10" />
                                        </Border.Shadow>
                                        <Grid RowDefinitions="130,Auto">
                                            <Grid HeightRequest="130">
                                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                                <Border StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 16"
                                                        BackgroundColor="{Binding AvailabilityBadgeBackgroundColor}"
                                                        HeightRequest="30"
                                                        WidthRequest="30"
                                                        HorizontalOptions="End"
                                                        VerticalOptions="Start"
                                                        Margin="8">
                                                    <Label Text="{Binding AvailabilityBadgeText}"
                                                           TextColor="White"
                                                           FontSize="14"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center" />
                                                </Border>
                                            </Grid>

                                            <VerticalStackLayout Grid.Row="1" Padding="10,8" Spacing="3">
                                                <Label Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="End"
                                                       LineBreakMode="TailTruncation" />
                                                <HorizontalStackLayout Spacing="2" HorizontalOptions="End">
                                                    <Label Text="📍" FontSize="12" />
                                                    <Label Text="{Binding Location}"
                                                           FontSize="12"
                                                           TextColor="#88636F"
                                                           LineBreakMode="TailTruncation" />
                                                </HorizontalStackLayout>
                                                <Grid ColumnDefinitions="Auto,*" FlowDirection="LeftToRight">
                                                    <HorizontalStackLayout Spacing="1">
                                                        <Label Text="{Binding RatingText}" FontSize="12" TextColor="#88636F" />
                                                        <Label Text="⭐" FontSize="10" />
                                                    </HorizontalStackLayout>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding PriceValueText}"
                                                           FontSize="16"
                                                           FontAttributes="Bold"
                                                           TextColor="#E6195D"
                                                           HorizontalTextAlignment="End" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Grid>

                    <Border IsVisible="{Binding IsHallsStatusVisible}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#FFFFFF"
                            Padding="12">
                        <Label Text="{Binding HallsStatusMessage}"
                               LineBreakMode="WordWrap"
                               HorizontalTextAlignment="End"
                               TextColor="#88636F"
                               FontSize="16" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsReservationsSectionVisible}" Spacing="12">
                    <Border StrokeThickness="0"
                            BackgroundColor="#FFFFFF"
                            Margin="-16,-18,-16,0"
                            Padding="0,0,0,4">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="*,*,*"
                                  FlowDirection="RightToLeft"
                                  Padding="12,0,12,0">
                                <Grid Grid.Column="0" RowDefinitions="Auto,3">
                                    <Button Text="الكل"
                                            Command="{Binding ShowAllReservationsFilterCommand}"
                                            FontSize="17"
                                            FontAttributes="Bold"
                                            TextColor="{Binding ReservationsAllTabColor}"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Padding="0,12" />
                                    <BoxView Grid.Row="1"
                                            Color="#E6195D"
                                            IsVisible="{Binding IsReservationsAllTabActive}" />
                                </Grid>

                                <Grid Grid.Column="1" RowDefinitions="Auto,3">
                                    <Button Text="القادمة"
                                            Command="{Binding ShowUpcomingReservationsFilterCommand}"
                                            FontSize="17"
                                            FontAttributes="Bold"
                                            TextColor="{Binding ReservationsUpcomingTabColor}"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Padding="0,12" />
                                    <BoxView Grid.Row="1"
                                            Color="#E6195D"
                                            IsVisible="{Binding IsReservationsUpcomingTabActive}" />
                                </Grid>

                                <Grid Grid.Column="2" RowDefinitions="Auto,3">
                                    <Button Text="المكتملة"
                                            Command="{Binding ShowCompletedReservationsFilterCommand}"
                                            FontSize="17"
                                            FontAttributes="Bold"
                                            TextColor="{Binding ReservationsCompletedTabColor}"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Padding="0,12" />
                                    <BoxView Grid.Row="1"
                                            Color="#E6195D"
                                            IsVisible="{Binding IsReservationsCompletedTabActive}" />
                                </Grid>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding BookingCards}" Spacing="12">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="bookingModels:BookingCard">
                                <Border Stroke="#E9E3E5"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 18"
                                        BackgroundColor="#FFFFFF"
                                        Padding="12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenReservationActionCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Border.Shadow>
                                        <Shadow Brush="#12000000" Offset="0,2" Radius="8" />
                                    </Border.Shadow>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsMuted}" Value="True">
                                            <Setter Property="Opacity" Value="0.84" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <VerticalStackLayout Spacing="10">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                            <Border Grid.Column="0"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 14"
                                                    HeightRequest="102"
                                                    WidthRequest="145">
                                                <Image Source="{Binding HallImageUrl}"
                                                       Aspect="AspectFill">
                                                    <Image.Triggers>
                                                        <DataTrigger TargetType="Image" Binding="{Binding IsMuted}" Value="True">
                                                            <Setter Property="Opacity" Value="0.65" />
                                                        </DataTrigger>
                                                    </Image.Triggers>
                                                </Image>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" Spacing="8">
                                                <Grid ColumnDefinitions="Auto,*" FlowDirection="LeftToRight">
                                                    <Border BackgroundColor="{Binding StatusBackgroundColor}"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 12"
                                                            Padding="10,4"
                                                            HorizontalOptions="Start">
                                                        <HorizontalStackLayout Spacing="3" FlowDirection="LeftToRight">
                                                            <Label Text="{Binding StatusText}"
                                                                   FontSize="14"
                                                                   FontAttributes="Bold"
                                                                   TextColor="{Binding StatusTextColor}" />
                                                            <Label Text="{Binding StatusIcon}"
                                                                   FontSize="14"
                                                                   FontAttributes="Bold"
                                                                   TextColor="{Binding StatusTextColor}" />
                                                        </HorizontalStackLayout>
                                                    </Border>

                                                    <Label Grid.Column="1"
                                                           Text="{Binding HallName}"
                                                           FontSize="20"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="End"
                                                           LineBreakMode="TailTruncation" />
                                                </Grid>

                                                <HorizontalStackLayout Spacing="4" HorizontalOptions="End">
                                                    <Label Text="📍" FontSize="14" />
                                                    <Label Text="{Binding HallLocation}"
                                                           FontSize="16"
                                                           TextColor="#617189"
                                                           LineBreakMode="TailTruncation" />
                                                </HorizontalStackLayout>

                                                <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                                    <Border StrokeThickness="0"
                                                            BackgroundColor="#EFF2F6"
                                                            StrokeShape="RoundRectangle 8"
                                                            Padding="10,6">
                                                        <Label Text="{Binding DateText}"
                                                               FontSize="15"
                                                               TextColor="#617189" />
                                                    </Border>

                                                    <Border IsVisible="{Binding ShowTime}"
                                                            StrokeThickness="0"
                                                            BackgroundColor="#EFF2F6"
                                                            StrokeShape="RoundRectangle 8"
                                                            Padding="10,6">
                                                        <Label Text="{Binding TimeText}"
                                                               FontSize="15"
                                                               TextColor="#617189" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <BoxView HeightRequest="1" Color="#EEF2F6" />

                                        <Grid ColumnDefinitions="Auto,*" FlowDirection="LeftToRight">
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding ActionIcon}"
                                                       FontSize="20"
                                                       TextColor="{Binding ActionTextColor}" />
                                                <Label Text="{Binding ActionText}"
                                                       FontSize="18"
                                                       FontAttributes="Bold"
                                                       TextColor="{Binding ActionTextColor}" />
                                            </HorizontalStackLayout>

                                            <Label Grid.Column="1"
                                                   IsVisible="{Binding ShowPrice}"
                                                   Text="{Binding PriceText}"
                                                   FontSize="30"
                                                   FontAttributes="Bold"
                                                   TextColor="{Binding PriceTextColor}"
                                                   HorizontalTextAlignment="End"
                                                   VerticalTextAlignment="Center" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Border IsVisible="{Binding IsReservationsStatusVisible}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#FFFFFF"
                            Padding="12">
                        <Label Text="{Binding ReservationsStatusMessage}"
                               LineBreakMode="WordWrap"
                               HorizontalTextAlignment="End"
                               TextColor="#617189"
                               FontSize="16" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsProfileSectionVisible}" Spacing="14">
                    <Border StrokeThickness="0"
                            BackgroundColor="#FFFFFF"
                            Padding="0,18,0,24"
                            Margin="-16,-18,-16,0">
                        <VerticalStackLayout Spacing="10">
                            <Grid HorizontalOptions="Center" Margin="0,4,0,0">
                                <Border HeightRequest="170"
                                        WidthRequest="170"
                                        Stroke="#F3D9E3"
                                        StrokeThickness="4"
                                        StrokeShape="RoundRectangle 85"
                                        Padding="3"
                                        HorizontalOptions="Center">
                                    <Image Source="{Binding ProfileAvatarUrl}"
                                           Aspect="AspectFill"
                                           HeightRequest="162"
                                           WidthRequest="162" />
                                </Border>

                                <Border HeightRequest="56"
                                        WidthRequest="56"
                                        StrokeThickness="0"
                                        BackgroundColor="#E6195D"
                                        StrokeShape="RoundRectangle 28"
                                        HorizontalOptions="End"
                                        VerticalOptions="End"
                                        Margin="0,0,-4,6">
                                    <Border.Shadow>
                                        <Shadow Brush="#26000000" Offset="0,3" Radius="8" />
                                    </Border.Shadow>
                                    <Label Text="📷"
                                           FontSize="18"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           TextColor="White" />
                                </Border>
                            </Grid>

                            <Label Text="{Binding UserName}"
                                   FontSize="52"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#181113" />

                            <Label Text="{Binding Email}"
                                   FontSize="22"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#617189" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="إعدادات الحساب"
                           FontSize="42"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End"
                           TextColor="#181113"
                           Margin="0,6,0,0" />

                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="#FFFFFF">
                        <Border.Shadow>
                            <Shadow Brush="#12000000" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  FlowDirection="LeftToRight"
                                  Padding="14,16">
                                <Label Text="‹"
                                       FontSize="40"
                                       TextColor="#95A3B8"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="1"
                                       Text="تعديل الملف الشخصي"
                                       FontSize="20"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center" />
                                <Border Grid.Column="2"
                                        HeightRequest="54"
                                        WidthRequest="54"
                                        BackgroundColor="#FCE7EF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="✎"
                                           FontSize="24"
                                           TextColor="#E6195D"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#EEF2F6" />

                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  FlowDirection="LeftToRight"
                                  Padding="14,16">
                                <Label Text="‹"
                                       FontSize="40"
                                       TextColor="#95A3B8"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="1"
                                       Text="إعدادات الإشعارات"
                                       FontSize="20"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center" />
                                <Border Grid.Column="2"
                                        HeightRequest="54"
                                        WidthRequest="54"
                                        BackgroundColor="#FCE7EF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="🔔"
                                           FontSize="23"
                                           TextColor="#E6195D"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#EEF2F6" />

                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  FlowDirection="LeftToRight"
                                  Padding="14,16">
                                <Label Text="‹"
                                       FontSize="40"
                                       TextColor="#95A3B8"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="1"
                                       Text="طرق الدفع"
                                       FontSize="20"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center" />
                                <Border Grid.Column="2"
                                        HeightRequest="54"
                                        WidthRequest="54"
                                        BackgroundColor="#FCE7EF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="💳"
                                           FontSize="23"
                                           TextColor="#E6195D"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="التفضيلات"
                           FontSize="42"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End"
                           TextColor="#181113"
                           Margin="0,6,0,0" />

                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="#FFFFFF">
                        <Border.Shadow>
                            <Shadow Brush="#12000000" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                  FlowDirection="LeftToRight"
                                  Padding="14,16">
                                <Label Text="‹"
                                       FontSize="40"
                                       TextColor="#95A3B8"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="1"
                                       Text="العربية"
                                       FontSize="18"
                                       TextColor="#617189"
                                       VerticalTextAlignment="Center"
                                       Margin="12,0,0,0" />
                                <Label Grid.Column="2"
                                       Text="اللغة"
                                       FontSize="20"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center" />
                                <Border Grid.Column="3"
                                        HeightRequest="54"
                                        WidthRequest="54"
                                        BackgroundColor="#FCE7EF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="🌐"
                                           FontSize="22"
                                           TextColor="#E6195D"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#EEF2F6" />

                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  FlowDirection="LeftToRight"
                                  Padding="14,16">
                                <Label Text="‹"
                                       FontSize="40"
                                       TextColor="#95A3B8"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="1"
                                       Text="المساعدة والدعم"
                                       FontSize="20"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center" />
                                <Border Grid.Column="2"
                                        HeightRequest="54"
                                        WidthRequest="54"
                                        BackgroundColor="#FCE7EF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="?"
                                           FontSize="26"
                                           FontAttributes="Bold"
                                           TextColor="#E6195D"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Button Text="تسجيل الخروج  ⎋"
                            Command="{Binding LogoutCommand}"
                            HeightRequest="64"
                            CornerRadius="18"
                            FontAttributes="Bold"
                            FontSize="22"
                            TextColor="#EF4444"
                            BorderColor="#D4DEE9"
                            BorderWidth="1"
                            BackgroundColor="#FFFFFF"
                            Margin="0,8,0,0" />
                </VerticalStackLayout>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#E6195D" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2"
                StrokeThickness="0"
                BackgroundColor="#FFFFFF"
                Padding="6,8,6,10">
            <Border.Shadow>
                <Shadow Brush="#13000000" Offset="0,-2" Radius="10" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="4">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowHomeCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="⌂" FontSize="24" TextColor="{Binding HomeTabColor}" HorizontalTextAlignment="Center" />
                    <Label Text="الرئيسية" FontSize="14" TextColor="{Binding HomeTabColor}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowReservationsCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="📅" FontSize="24" TextColor="{Binding ReservationsTabColor}" HorizontalTextAlignment="Center" />
                    <Label Text="حجوزاتي" FontSize="14" TextColor="{Binding ReservationsTabColor}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowHallsCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="🏛" FontSize="24" TextColor="{Binding HallsTabColor}" HorizontalTextAlignment="Center" />
                    <Label Text="الصالات" FontSize="14" TextColor="{Binding HallsTabColor}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowProfileCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="👤" FontSize="24" TextColor="{Binding ProfileTabColor}" HorizontalTextAlignment="Center" />
                    <Label Text="الملف الشخصي" FontSize="14" TextColor="{Binding ProfileTabColor}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>

</ContentPage>

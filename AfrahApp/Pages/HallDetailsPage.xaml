<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:AfrahApp.ViewModels"
             x:Class="AfrahApp.Pages.HallDetailsPage"
             x:DataType="viewModels:HallDetailsViewModel"
             FlowDirection="RightToLeft"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F6F6"
             Title="تفاصيل الصالة">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="#FFFFFF"
                Padding="12,14">
            <Border.Shadow>
                <Shadow Brush="#12000000" Offset="0,2" Radius="8" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto"
                  FlowDirection="LeftToRight"
                  VerticalOptions="Center">
                <Button Text="{Binding FavoriteIcon}"
                        Command="{Binding ToggleFavoriteCommand}"
                        TextColor="{Binding FavoriteIconColor}"
                        FontSize="24"
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        Padding="0"
                        HeightRequest="40"
                        WidthRequest="40" />

                <Label Grid.Column="1"
                       Text="تفاصيل الصالة"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="#181113" />

                <Button Grid.Column="2"
                        Text="→"
                        Command="{Binding BackCommand}"
                        FontSize="26"
                        BackgroundColor="Transparent"
                        TextColor="#181113"
                        BorderWidth="0"
                        Padding="0"
                        HeightRequest="40"
                        WidthRequest="40" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="16">
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding GalleryImages}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 20"
                                        WidthRequest="380"
                                        HeightRequest="250">
                                    <Border.Shadow>
                                        <Shadow Brush="#13000000" Offset="0,2" Radius="8" />
                                    </Border.Shadow>
                                    <Image Source="{Binding .}" Aspect="AspectFill" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <Label Text="{Binding GalleryStatusText}"
                       IsVisible="{Binding IsGalleryStatusVisible}"
                       FontSize="16"
                       TextColor="#617189"
                       HorizontalTextAlignment="End" />

                <Grid ColumnDefinitions="Auto,*" FlowDirection="LeftToRight">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Start">
                        <Border BackgroundColor="{Binding AvailabilityBackgroundColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,6"
                                HorizontalOptions="Start">
                            <Label Text="{Binding AvailabilityText}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{Binding AvailabilityTextColor}" />
                        </Border>

                        <HorizontalStackLayout Spacing="4" HorizontalOptions="Start">
                            <Label Text="{Binding RatingText}"
                                   FontSize="30"
                                   FontAttributes="Bold"
                                   TextColor="#181113" />
                            <Label Text="⭐" FontSize="18" />
                            <Label Text="{Binding ReviewsCountText}"
                                   FontSize="14"
                                   TextColor="#8A6E77"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                        <Label Text="{Binding HallName}"
                               FontSize="40"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="End"
                               LineBreakMode="TailTruncation" />
                        <HorizontalStackLayout Spacing="4" HorizontalOptions="End">
                            <Label Text="📍" FontSize="17" />
                            <Label Text="{Binding Location}"
                                   FontSize="16"
                                   TextColor="#8A6E77"
                                   LineBreakMode="TailTruncation" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="#FFFFFF"
                            Padding="12">
                        <Border.Shadow>
                            <Shadow Brush="#12000000" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="*,Auto" FlowDirection="LeftToRight">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="السعر يبدأ من"
                                       FontSize="14"
                                       TextColor="#8A6E77"
                                       HorizontalTextAlignment="End" />
                                <Label Text="{Binding PriceValueText}"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    HeightRequest="42"
                                    WidthRequest="42"
                                    BackgroundColor="#EAF8EF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 21"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                                <Label Text="💵"
                                       FontSize="20"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="#FFFFFF"
                            Padding="12">
                        <Border.Shadow>
                            <Shadow Brush="#12000000" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="*,Auto" FlowDirection="LeftToRight">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="السعة"
                                       FontSize="14"
                                       TextColor="#8A6E77"
                                       HorizontalTextAlignment="End" />
                                <Label Text="{Binding CapacityRangeText}"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    HeightRequest="42"
                                    WidthRequest="42"
                                    BackgroundColor="#EEF4FF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 21"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                                <Label Text="👥"
                                       FontSize="20"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <VerticalStackLayout Spacing="8">
                    <Label Text="عن الصالة"
                           FontSize="34"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />

                    <Label Text="{Binding AboutText}"
                           FontSize="18"
                           TextColor="#283349"
                           HorizontalTextAlignment="End"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Label Text="الخدمات المتوفرة"
                           FontSize="34"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />

                    <FlexLayout Wrap="Wrap"
                                Direction="Row"
                                FlowDirection="RightToLeft"
                                JustifyContent="Start"
                                AlignItems="Start"
                                BindableLayout.ItemsSource="{Binding Services}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border BackgroundColor="#EFF2F6"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="12,8"
                                        Margin="0,0,8,8">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="✓" FontSize="15" />
                                        <Label Text="{Binding .}" FontSize="16" TextColor="#283349" />
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <Label Text="{Binding ServicesStatusText}"
                           IsVisible="{Binding IsServicesStatusVisible}"
                           FontSize="16"
                           TextColor="#617189"
                           HorizontalTextAlignment="End" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8" IsVisible="{Binding IsMapVisible}">
                    <Label Text="الموقع على الخريطة"
                           FontSize="34"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />

                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            HeightRequest="180">
                        <Border.Shadow>
                            <Shadow Brush="#12000000" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <Image Source="{Binding MapImageUrl}" Aspect="AspectFill" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="التقييمات"
                           FontSize="34"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End" />

                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="#FFFFFF"
                            Padding="14">
                        <Border.Shadow>
                            <Shadow Brush="#12000000" Offset="0,2" Radius="8" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="{Binding RatingText}"
                                   FontSize="56"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="⭐"
                                   FontSize="20"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#E59A10" />
                            <Label Text="{Binding ReviewsCountText}"
                                   FontSize="16"
                                   TextColor="#617189"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding RatingsSummaryText}"
                                   FontSize="15"
                                   TextColor="#617189"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2"
                StrokeThickness="0"
                BackgroundColor="#FFFFFF"
                Padding="16,10,16,16">
            <Border.Shadow>
                <Shadow Brush="#13000000" Offset="0,-2" Radius="10" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto" FlowDirection="LeftToRight" ColumnSpacing="12">
                <Button Text="احجز الآن"
                        Command="{Binding BookNowCommand}"
                        BackgroundColor="#E6195D"
                        TextColor="White"
                        FontSize="22"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        HeightRequest="56"
                        BorderWidth="0" />

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="0">
                    <Label Text="السعر الإجمالي"
                           FontSize="14"
                           TextColor="#8A6E77"
                           HorizontalTextAlignment="End" />
                    <Label Text="{Binding PriceValueText}"
                           FontSize="36"
                           FontAttributes="Bold"
                           TextColor="#E6195D"
                           HorizontalTextAlignment="End" />
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>

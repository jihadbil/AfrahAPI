//@AfrahAPI_HostAddress = https://localhost:7026
@AfrahAPI_Http_HostAddress = http://localhost:5026

###############################################################################
# AUTHENTICATION - المصادقة وإدارة الحسابات
###############################################################################

### Get Available Roles - الحصول على الأدوار المتاحة
GET {{AfrahAPI_Http_HostAddress}}/api/account/roles
Accept: application/json

### Register New Customer - تسجيل عميل جديد
POST {{AfrahAPI_Http_HostAddress}}/api/account/register
Content-Type: application/json

{
  "email": "customer@example.com",
  "userName": "customer1",
  "password": "Customer@123",
  "confirmPassword": "Customer@123",
  "phoneNumber": "0501234567",
  "role": "Customer"
}

### Register New Hall Owner - تسجيل صاحب صالة جديد
POST {{AfrahAPI_Http_HostAddress}}/api/account/register
Content-Type: application/json

{
  "email": "owner@example.com",
  "userName": "hallowner1",
  "password": "Owner@123",
  "confirmPassword": "Owner@123",
  "phoneNumber": "0509876543",
  "role": "HallOwner"
}

### Register Admin - تسجيل مسؤول
POST {{AfrahAPI_Http_HostAddress}}/api/account/register
Content-Type: application/json

{
  "email": "admin@afrahapi.com",
  "userName": "admin",
  "password": "Admin@123456",
  "confirmPassword": "Admin@123456",
  "phoneNumber": "0501111111",
  "role": "Admin"
}

### Login - تسجيل الدخول
POST {{AfrahAPI_Http_HostAddress}}/api/account/login
Content-Type: application/json

{
  "emailOrUserName": "admin@afrahapi.com",
  "password": "Admin@123456"
}

### Login with Customer - تسجيل دخول عميل
POST {{AfrahAPI_Http_HostAddress}}/api/account/login
Content-Type: application/json

{
  "emailOrUserName": "customer@example.com",
  "password": "Customer@123"
}

### Change Password - تغيير كلمة المرور (يحتاج Token)
# احصل على Token من Login أولاً وضعه في Authorization header
POST {{AfrahAPI_Http_HostAddress}}/api/account/change-password
Content-Type: application/json
Authorization: Bearer YOUR_JWT_TOKEN_HERE

{
  "currentPassword": "Admin@123456",
  "newPassword": "NewAdmin@123456",
  "confirmNewPassword": "NewAdmin@123456"
}

###############################################################################
# 1. HALL CONTROLLER - إدارة الصالات
###############################################################################

### Get All Halls - الحصول على جميع الصالات
GET {{AfrahAPI_Http_HostAddress}}/api/hall
Accept: application/json

### Get Hall By ID - الحصول على صالة محددة
GET {{AfrahAPI_Http_HostAddress}}/api/hall/00000000-0000-0000-0000-000000000001
Accept: application/json

### Create New Hall - إنشاء صالة جديدة
POST {{AfrahAPI_Http_HostAddress}}/api/hall
Content-Type: application/json

{
  "hallName": "قاعة الأفراح الذهبية",
  "description": "قاعة فاخرة لحفلات الزفاف",
  "address": "الرياض، حي الملك فهد",
  "latitude": 24.7136,
  "longitude": 46.6753,
  "capacity": 500,
  "pricingMode": "PerDay",
  "pricePerHour": 0,
  "pricePerDay": 15000,
  "defaultDepositAmount": 5000,
  "isAvailable": true,
  "allowsMultipleReservationsPerDay": false,
  "autoAcceptReservations": false,
  "mainImageUrl": "https://example.com/hall1.jpg",
  "cancellationPolicy": "الإلغاء قبل أسبوع من الموعد بدون رسوم",
  "baseCommissionRate": 10,
  "ownerUserID": "00000000-0000-0000-0000-000000000001",
  "categoryID": "00000000-0000-0000-0000-000000000001"
}

### Update Hall - تحديث صالة
PUT {{AfrahAPI_Http_HostAddress}}/api/hall/00000000-0000-0000-0000-000000000001
Content-Type: application/json

{
  "hallName": "قاعة الأفراح الذهبية المحدثة",
  "description": "قاعة فاخرة لحفلات الزفاف - محدثة",
  "pricePerDay": 18000
}

### Delete Hall - حذف صالة
DELETE {{AfrahAPI_Http_HostAddress}}/api/hall/00000000-0000-0000-0000-000000000001

### Search Halls - البحث عن صالات
POST {{AfrahAPI_Http_HostAddress}}/api/hall/search
Content-Type: application/json

{
  "categoryId": "00000000-0000-0000-0000-000000000001",
  "minCapacity": 200,
  "maxPrice": 20000
}

### Get Available Halls - الحصول على الصالات المتاحة
GET {{AfrahAPI_Http_HostAddress}}/api/hall/available?startDate=2026-02-01&endDate=2026-02-02
Accept: application/json

### Check Hall Availability - فحص توفر صالة
GET {{AfrahAPI_Http_HostAddress}}/api/hall/00000000-0000-0000-0000-000000000001/availability?startDate=2026-02-01&endDate=2026-02-02
Accept: application/json

### Get Halls By Owner - الحصول على صالات مالك
GET {{AfrahAPI_Http_HostAddress}}/api/hall/owner/00000000-0000-0000-0000-000000000001
Accept: application/json

### Get Halls By Category - الحصول على صالات حسب الفئة
GET {{AfrahAPI_Http_HostAddress}}/api/hall/category/00000000-0000-0000-0000-000000000001
Accept: application/json

### Verify Hall - التحقق من الصالة
POST {{AfrahAPI_Http_HostAddress}}/api/hall/00000000-0000-0000-0000-000000000001/verify

### Update Hall Availability - تحديث حالة التوفر
PUT {{AfrahAPI_Http_HostAddress}}/api/hall/00000000-0000-0000-0000-000000000001/availability
Content-Type: application/json

true

